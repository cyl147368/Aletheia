# Aletheia 环境变量
# 复制此文件为 .env 并修改

# 加密密钥（用于存储中转站 API Key），留空自动生成
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ALETHEIA_ENCRYPTION_KEY=

# JWT 密钥，留空自动生成
ALETHEIA_JWT_SECRET=

# 管理员初始密码，留空自动生成并打印在日志中
ALETHEIA_ADMIN_PASSWORD=

# 默认探测间隔（小时）
ALETHEIA_DEFAULT_PROBE_INTERVAL_HOURS=6